# Python virtual environment — thousands of files, never upload
ml/venv/

# Python cache files — auto-generated, not needed
ml/__pycache__/
ml/**/__pycache__/

# Secret keys — never upload to GitHub
ml/.env

# Node dependencies — re-installed automatically on deploy
backend/node_modules/
frontend/node_modules/

# Secret keys for backend
backend/.env

# Angular build cache — not needed
frontend/.angular/

# Angular compiled output — Vercel builds this fresh
frontend/dist/

# Mac junk files
.DS_Store

# Python compiled files
*.pyc